# Normalize line endings to LF in the repo (avoids CRLF churn/warnings on Windows).
* text=auto eol=lf

# Explicit text types
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.mp4   binary
