EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostHog analytics (optional in dev — leave blank to disable analytics).
# The project API key (phc_…) is a write-only PUBLIC key, safe to ship.
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry crash reporting (optional — leave blank to disable).
# The DSN is a publishable client identifier, safe to ship. Source-map upload
# (readable traces) additionally needs SENTRY_AUTH_TOKEN as an EAS secret.
EXPO_PUBLIC_SENTRY_DSN=
